GATEWAY_BASE_PATH=/emby
# Optional. Set this to the public gateway base URL in production.
GATEWAY_PUBLIC_URL=http://localhost:8090/emby
GATEWAY_SERVER_ID=emby-auth-gateway-dev
GATEWAY_PORT=8090

# Used only with docker-compose.dev.yml.
EMBY_PORT=8096
EMBY_UID=1000
EMBY_GID=1000
EMBY_GIDLIST=1000
EMBY_MEDIA_DIR=./tmp/emby-media

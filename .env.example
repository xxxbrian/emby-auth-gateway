# Optional. Set this to the public gateway base URL in production (must end with /emby).
GATEWAY_PUBLIC_URL=http://localhost:8090/emby
GATEWAY_SERVER_ID=emby-auth-gateway-dev
GATEWAY_PORT=8090

# Emby Web assets root. Blank (default) disables Web serving so the gateway
# stays API-only. Emby-compatible routes are always under fixed /emby.
#
# The directory must be a web root (index.html, manifest.json, strings/en-US.json
# at the top level). Gateway trusts the directory contents; it does not install
# or hash-verify assets.
#
# Local binary:
#   GATEWAY_WEB_ASSETS_DIR=/path/to/web-root
#
# Compose overlay (docker-compose.web.yml):
#   GATEWAY_WEB_ASSETS_HOST=/absolute/path/to/web-root
#   docker compose -f docker-compose.yml -f docker-compose.web.yml up --build -d
GATEWAY_WEB_ASSETS_DIR=

# Optional shared image tag for the gateway Compose service.
# GATEWAY_IMAGE=emby-auth-gateway:local

# Used only with docker-compose.dev.yml.
EMBY_PORT=8096
EMBY_UID=1000
EMBY_GID=1000
EMBY_GIDLIST=1000
EMBY_MEDIA_DIR=./tmp/emby-media

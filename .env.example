# Optional. Set this to the public gateway base URL in production (must end with /emby).
GATEWAY_PUBLIC_URL=http://localhost:8090/emby
GATEWAY_SERVER_ID=emby-auth-gateway-dev
GATEWAY_PORT=8090

# Emby Web assets root. Blank (default) disables Web serving so the gateway
# stays API-only. Emby-compatible routes are always under fixed /emby.
# Compose always mounts named volume gateway_web_assets at /app/web_assets
# (read-only on gateway; read-write on the profile-gated `web` one-shot service).
# To enable Web in Compose after assets are installed into that volume, set exactly:
#   GATEWAY_WEB_ASSETS_DIR=/app/web_assets

# Built-in production catalog ID: emby-web-4.9.5.0 (metadata only; official asset
# bytes are not in the image/repo). Install is always an explicit CLI action with
# a legally obtained prepared source:
#   docker compose run --rm web status --verify
#   docker compose run --rm web install --catalog-id emby-web-4.9.5.0 --from-dir|--from-archive|--from-url ...
GATEWAY_WEB_ASSETS_DIR=

# Optional shared image tag for gateway + web Compose services.
# GATEWAY_IMAGE=emby-auth-gateway:local

# Used only with docker-compose.web.yml (one-command Web init deployment).
# GATEWAY_WEB_CATALOG_ID=emby-web-4.9.5.0
# GATEWAY_WEB_SOURCE_KIND=dir
# GATEWAY_WEB_SOURCE_MOUNT=/absolute/path/to/prepared-tree-or-archive
#
# Remote archive (HTTPS .tar.gz). Leave GATEWAY_WEB_SOURCE_MOUNT unset:
# GATEWAY_WEB_SOURCE_KIND=archive
# GATEWAY_WEB_SOURCE_VALUE=https://assets.example.com/emby-web-prepared-4.9.5.0.tar.gz
#
# Static-tree URL mode (per-file tree, trailing slash; not a .tar.gz):
# GATEWAY_WEB_SOURCE_KIND=url
# GATEWAY_WEB_SOURCE_VALUE=https://assets.example.com/emby-web/4.9.5.0/

# Used only with docker-compose.dev.yml.
EMBY_PORT=8096
EMBY_UID=1000
EMBY_GID=1000
EMBY_GIDLIST=1000
EMBY_MEDIA_DIR=./tmp/emby-media

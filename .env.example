# Do not use this sample value outside local development. Generate a long random value.
GATEWAY_SECRET_KEY=change-me-generate-a-long-random-secret
GATEWAY_BASE_PATH=/emby
# Optional. When unset, docker-compose derives this from GATEWAY_PORT and GATEWAY_BASE_PATH.
GATEWAY_SERVER_ID=emby-auth-gateway-dev
GATEWAY_PORT=8090

EMBY_PORT=8096
EMBY_UID=1000
EMBY_GID=1000
EMBY_GIDLIST=1000
EMBY_MEDIA_DIR=./tmp/emby-media
